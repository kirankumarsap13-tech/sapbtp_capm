COLUMN TABLE kiran_db_master_businesspartner (
  NODE_KEY NVARCHAR(32) NOT NULL,
  BP_ROLE NVARCHAR(2),
  EMAIL_ADDRESS NVARCHAR(105),
  PHONENUMBER NVARCHAR(32),
  FAX_NUMBER NVARCHAR(32),
  WEB_ADDRESS NVARCHAR(44),
  ADDRESS_GUID_NODE_KEY NVARCHAR(32),
  BP_ID NVARCHAR(32),
  COMAPNY_NAME NVARCHAR(250),
  PRIMARY KEY(NODE_KEY)
)