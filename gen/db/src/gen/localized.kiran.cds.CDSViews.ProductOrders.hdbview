VIEW localized_kiran_cds_CDSViews_ProductOrders AS SELECT
  product_0.NODE_KEY AS ProductKey,
  product_0.DESCRIPTION AS ProductName,
  product_0.PRICE AS Price,
  SUPPLIER_GUID_1.BP_ID AS SupplierId,
  SUPPLIER_GUID_1.COMAPNY_NAME AS SupplierName,
  ADDRESS_GUID_2.COUNTRY AS Country
FROM ((localized_kiran_db_master_product AS product_0 LEFT JOIN kiran_db_master_businesspartner AS SUPPLIER_GUID_1 ON product_0.SUPPLIER_GUID_NODE_KEY = SUPPLIER_GUID_1.NODE_KEY) LEFT JOIN kiran_db_master_address AS ADDRESS_GUID_2 ON SUPPLIER_GUID_1.ADDRESS_GUID_NODE_KEY = ADDRESS_GUID_2.NODE_KEY)