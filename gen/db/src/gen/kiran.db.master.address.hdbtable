COLUMN TABLE kiran_db_master_address (
  NODE_KEY NVARCHAR(32) NOT NULL,
  CITY NVARCHAR(44),
  POSTAL_CODE NVARCHAR(8),
  STREET NVARCHAR(44),
  BUILDING NVARCHAR(128),
  COUNTRY NVARCHAR(3),
  ADDRESS_TYPE NVARCHAR(44),
  VAL_START_DATE DATE,
  VAL_END_DATE DATE,
  LATTITUDE DECIMAL,
  LONGITUDE DECIMAL,
  PRIMARY KEY(NODE_KEY)
)