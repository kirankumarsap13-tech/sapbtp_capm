COLUMN TABLE kirandb_trans_rentals (
  ID NVARCHAR(36) NOT NULL,
  validFrom TIMESTAMP NOT NULL,
  validTo TIMESTAMP,
  createdAt TIMESTAMP,
  createdBy NVARCHAR(255),
  modifiedAt TIMESTAMP,
  modifiedBy NVARCHAR(255),
  student_ID NVARCHAR(32),
  book_ID NVARCHAR(32),
  PRIMARY KEY(ID, validFrom)
)