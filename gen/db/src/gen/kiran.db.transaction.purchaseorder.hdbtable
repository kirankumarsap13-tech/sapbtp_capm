COLUMN TABLE kiran_db_transaction_purchaseorder (
  CURRENCY_code NVARCHAR(3),
  GROSS_AMOUNT DECIMAL(10, 2),
  NET_AMOUNT DECIMAL(10, 2),
  TAX_AMOUNT DECIMAL(10, 2),
  NODE_KEY NVARCHAR(32) NOT NULL,
  PO_ID NVARCHAR(40),
  PARTNER_GUID_NODE_KEY NVARCHAR(32),
  LIFECYCLE_STATUS NVARCHAR(1),
  OVERALL_STATUS NVARCHAR(1),
  PRIMARY KEY(NODE_KEY)
)