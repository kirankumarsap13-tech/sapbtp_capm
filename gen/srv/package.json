{
  "name": "capmapp",
  "version": "1.0.0",
  "description": "A Simple CAP Project",
  "license": "UNLICENSED",
  "private": "true",
  "dependencies": {
    "@cap-js-community/odata-v2-adapter": "^1.15.9",
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "express": "^5",
    "sqlite3": "^5",
    "@sap/xssec": "^4",
    "passport": "^0"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "node node_modules/@sap/approuter/approuter.js",
    "spiderman": "cds watch",
    "watch-studentapp": "cds watch --open com.student.studentapp/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "sapux": [
    "app/studentapp"
  ],
  "cds": {
    "requires": {
      "[production]": {
        "db": "hana",
        "uaa": {
          "kind": "xsuaa"
        },
        "auth": {
          "[development]": {
            "strategy": "mocked",
            "users": {
              "kiran": {
                "roles": [
                  "Viewer"
                ],
                "userAttributes": {
                  "BankName": []
                }
              },
              "KKK": {
                "roles": [
                  "Viewer"
                ],
                "userAttributes": {
                  "BankName": []
                }
              }
            }
          },
          "[production]": {
            "strategy": "JWT"
          }
        }
      }
    }
  },
  "engines": {
    "node": ">=20"
  }
}