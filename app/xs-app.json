{
  "welcomeFile": "studentapp/webapp/",
  "authenticationMethod": "route",
  "sessionTimeout": 10,
  "routes": [				
    {
      "source": "^/studentapp/webapp/(.*)$",
      "target": "$1",
      "localDir": "studentapp/webapp/",
      "authenticationType":"xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/(.*)$",
      "authenticationType":"xsuaa",
      "destination": "srv-api",
      "csrfProtection": false
    }  	  
  ],
  "logout": {
     "logoutEndpoint": "/my/logout",
     "logoutPage": "/logout-page.html"
  } 
}